---
interface Props {
  card: any;
}

const { card } = Astro.props;
const alt =
  card.kind === 'milestone'
    ? `${card.player} milestone card — ${card.value} ${card.stat}`
    : `${card.player} ${card.series} card`;
---

<div class="tcard" role="button" tabindex="0" aria-label={`${alt}. Tap to flip.`}>
  <div class="tcard-inner">
    <div class="tcard-front">
      <img src={card.img} alt={alt} loading="lazy" decoding="async" />
      {card.living && (
        <>
          <video
            class="tcard-live"
            src={`/cards/living/${card.asset}.mp4`}
            poster={card.img}
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            aria-hidden="true"></video>
          <span class="tcard-live-badge">● LIVE</span>
        </>
      )}
    </div>
    <div class="tcard-back">
      <div class="tb-head">
        <span class="tb-leaf" aria-hidden="true">🍁</span>
        <span class="tb-brand">MAPLE TREE<br /><em>{card.series}</em></span>
        <span class="tb-num">No. {card.number}<span>/{card.total}</span></span>
      </div>
      <div class="tb-title">
        {card.player}
        <span class="tb-sub">
          {card.kind === 'milestone'
            ? `${card.value} ${card.stat} · Milestone`
            : card.kind === 'special'
              ? card.caption
              : `${card.rating} OVR · Base Card`}
        </span>
      </div>
      <p class="tb-flavor">{card.flavor}</p>
      {card.game_text && <p class="tb-game">{card.game_text}</p>}
      <dl class="tb-facts">
        {card.facts.map((f: string[]) => (
          <>
            <dt>{f[0]}</dt>
            <dd>{f[1]}</dd>
          </>
        ))}
      </dl>
      <div class="tb-foot">
        {card.kind === 'milestone' && card.caption ? `${card.caption} · ` : ''}The Maple Tree Tap · Cary, Illinois
      </div>
    </div>
  </div>
</div>

<script>
  // Living cards: play the loop only while on screen, fade it over the still.
  const initLiving = () => {
    const vids = document.querySelectorAll('video.tcard-live:not([data-obs])');
    if (!vids.length) return;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          const v = e.target as HTMLVideoElement;
          if (e.isIntersecting) {
            v.play().then(() => v.classList.add('playing')).catch(() => {});
          } else {
            v.pause();
            v.classList.remove('playing');
          }
        });
      },
      { rootMargin: '200px', threshold: 0.01 },
    );
    vids.forEach((v) => {
      (v as HTMLElement).dataset.obs = '1';
      const vid = v as HTMLVideoElement;
      // reveal once the loop can render (autoplay handles playback where allowed)
      if (vid.readyState >= 2) vid.classList.add('playing');
      vid.addEventListener('playing', () => vid.classList.add('playing'), { once: true });
      io.observe(v);
    });
  };
  initLiving();
  document.addEventListener('astro:page-load', initLiving);
</script>
