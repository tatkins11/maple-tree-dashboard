---
import meta from '../data/meta.json';
import { datePretty } from '../lib/fmt';
---

<footer class="site-foot">
  <div class="wrap foot-row">
    <div class="foot-left">
      <img
        class="foot-logo"
        src="/brand/maple-tree-tap.webp"
        alt="The Maple Tree Tap — Cary, Illinois"
        width="104"
        height="104"
        loading="lazy"
      />
      <div>
        <div class="foot-brand">Maple Tree Softball</div>
        <div class="foot-line">Wednesday Men's League · Recreational Division · Boncosky Park</div>
        <div class="foot-line">
          Franchise lineage: Soviet Sluggers ’21 → Smoking Bunts ’22 → Maple Tree Tappers ’25 → Maple Tree
        </div>
        <div class="foot-line foot-credit">The Maple Tree Tap · Cary, Illinois</div>
      </div>
    </div>
    <div class="foot-meta">
      <img
        class="foot-crest"
        src="/brand/retro-badge.svg"
        alt="Maple Tree Softball club crest"
        width="92"
        height="92"
        loading="lazy"
      />
      <div>Stats through {meta.data_through ? datePretty(meta.data_through) : '—'}</div>
    </div>
  </div>
</footer>
